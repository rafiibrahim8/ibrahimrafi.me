---
import Base from '../../layouts/Base.astro';
import Prose from '../../components/Prose.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('writing', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

type Props = { post: CollectionEntry<'writing'> };

const { post } = Astro.props;
const { Content, headings } = await render(post);

const date = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const toc = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

<Base
  title={post.data.title}
  description={`${post.data.title} — a post by Ibrahim Rafi.`}
>
  <article>
    <p class="meta post-meta">
      {date}
      {post.data.tags.map((t) => <span class="tag">#{t}</span>)}
    </p>
    <h1 class="display post-title">
      <span class="emoji">{post.data.emoji}</span>{post.data.title}
    </h1>

    {
      toc.length > 1 && (
        <details class="toc">
          <summary>Contents</summary>
          <ul>
            {toc.map((h) => (
              <li class:list={[`d${h.depth}`]}>
                <a href={`#${h.slug}`}>{h.text}</a>
              </li>
            ))}
          </ul>
        </details>
      )
    }

    <Prose>
      <Content />
    </Prose>
  </article>
</Base>

<script>
  const ICON_COPY =
    '<svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true"><path fill="currentColor" d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 0 1 0 1.5h-1.5a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-1.5a.75.75 0 0 1 1.5 0v1.5A1.75 1.75 0 0 1 9.25 16h-7.5A1.75 1.75 0 0 1 0 14.25Z"/><path fill="currentColor" d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0 1 14.25 11h-7.5A1.75 1.75 0 0 1 5 9.25Zm1.75-.25a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-7.5a.25.25 0 0 0-.25-.25Z"/></svg>';
  const ICON_DONE =
    '<svg viewBox="0 0 16 16" width="16" height="16" aria-hidden="true"><path fill="currentColor" d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.751.751 0 0 1 .018-1.042.751.751 0 0 1 1.042-.018L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z"/></svg>';

  document.querySelectorAll<HTMLPreElement>('.prose pre').forEach((pre) => {
    const code = pre.querySelector('code');
    if (!code) return;

    // Wrap the <pre> so the copy button sits on a non-scrolling container —
    // otherwise it scrolls away with the code on horizontal overflow.
    const wrap = document.createElement('div');
    wrap.className = 'code-wrap';
    pre.replaceWith(wrap);
    wrap.appendChild(pre);

    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = 'copy-btn';
    btn.innerHTML = ICON_COPY;
    btn.setAttribute('aria-label', 'Copy code to clipboard');

    let resetTimer: ReturnType<typeof setTimeout>;
    btn.addEventListener('click', async () => {
      try {
        await navigator.clipboard.writeText(code.innerText);
        btn.innerHTML = ICON_DONE;
        btn.classList.add('done');
        btn.setAttribute('aria-label', 'Copied');
        clearTimeout(resetTimer);
        resetTimer = setTimeout(() => {
          btn.innerHTML = ICON_COPY;
          btn.classList.remove('done');
          btn.setAttribute('aria-label', 'Copy code to clipboard');
        }, 1600);
      } catch {
        /* clipboard blocked — leave the icon as-is */
      }
    });

    wrap.appendChild(btn);
  });
</script>

<style>
  .post-meta {
    margin-bottom: 14px;
  }

  .tag {
    color: var(--accent);
    margin-left: 12px;
  }

  .post-title {
    font-size: clamp(40px, 7vw, 76px);
    line-height: 1.1;
    margin-bottom: 36px;
    text-transform: none;
  }

  .post-title .emoji {
    margin-right: 0.15em;
  }

  .toc {
    border: 2px solid var(--ink);
    padding: 14px 18px;
    margin-bottom: 40px;
    max-width: 480px;
    box-shadow: 4px 4px 0 var(--ink);
  }

  .toc summary {
    font-family: var(--font-mono);
    font-size: 14px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    cursor: pointer;
  }

  .toc ul {
    list-style: none;
    padding: 12px 0 4px;
    margin: 0;
  }

  .toc li {
    margin-bottom: 6px;
  }

  .toc li.d3 {
    padding-left: 20px;
  }

  .toc a {
    color: var(--ink);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
  }

  .toc a:hover {
    color: var(--accent);
  }
</style>
