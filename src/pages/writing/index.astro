---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf(),
);

// Absolute date is the no-JS fallback; the client script below swaps in a live
// "x ago" relative time so it never goes stale on this statically-built site.
const fmtDate = (date: Date) =>
  date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric',
  });
---

<Base
  title="Writing"
  description="Posts by Ibrahim Rafi on self-hosting, Linux, security, and small sharp tools."
>
  <h1 class="page-title">Writing</h1>

  <div class="posts">
    {
      posts.map((post) => (
        <article class="entry">
          <p class="meta entry-meta">
            <time class="ago" datetime={post.data.date.toISOString()}>
              {fmtDate(post.data.date)}
            </time>
            {post.data.tags.map((t) => (
              <span class="tag">#{t}</span>
            ))}
          </p>
          <a class="title" href={`/writing/${post.id}`}>
            <span class="emoji">{post.data.emoji}</span> {post.data.title}
          </a>
        </article>
      ))
    }
    {posts.length === 0 && <p class="meta">nothing here yet — soon.</p>}
  </div>
</Base>

<script>
  // Hydrate <time class="ago"> with a live relative time computed in the browser,
  // so "x days ago" reflects the visitor's current date, not the build date.
  const rtf = new Intl.RelativeTimeFormat('en', { numeric: 'auto' });
  const DAY = 86_400_000;

  for (const el of document.querySelectorAll<HTMLTimeElement>('time.ago')) {
    const then = new Date(el.dateTime).getTime();
    if (Number.isNaN(then)) continue;
    const days = Math.round((then - Date.now()) / DAY);
    const abs = Math.abs(days);
    el.textContent =
      abs < 30
        ? rtf.format(days, 'day')
        : abs < 365
          ? rtf.format(Math.round(days / 30), 'month')
          : rtf.format(Math.round(days / 365), 'year');
  }
</script>

<style>
  .posts {
    max-width: 820px;
  }

  .entry {
    margin-bottom: 40px;
  }

  .entry-meta {
    margin-bottom: 6px;
  }

  .tag {
    color: var(--accent);
    margin-left: 12px;
  }

  .title {
    font-size: 23px;
    font-weight: 600;
    color: var(--ink);
    text-decoration: none;
    line-height: 1.3;
  }

  .title:hover {
    color: var(--accent);
  }

  .emoji {
    margin-right: 4px;
  }
</style>
