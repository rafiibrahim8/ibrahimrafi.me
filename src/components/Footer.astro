---
const year = new Date().getFullYear();
const isHome = Astro.url.pathname === '/';
---

<footer>
  <span>© {year} Ibrahim Rafi</span>
  {
    isHome && (
      <span class="hint">
        <a href="/steg">this page is hiding something. find it.</a>
      </span>
    )
  }
</footer>

<style>
  footer {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    padding: 56px var(--pad-x) 32px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--muted);
  }

  .hint {
    opacity: 0.6;
  }

  .hint::before {
    content: '> ';
    color: var(--accent);
  }

  .hint a {
    color: inherit;
    text-decoration: none;
  }

  .hint a:hover {
    color: var(--accent);
  }
</style>
